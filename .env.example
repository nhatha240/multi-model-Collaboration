ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Cloud coder (OpenAI) ──────────────────────────────────────────────────────
# Leave blank if using local codex below
OPENAI_API_KEY=sk-your-key-here

# ── Local codex (Ollama / LM Studio / llama.cpp) ─────────────────────────────
# Set CODEX_BASE_URL to enable local mode — OPENAI_API_KEY becomes optional.
#
# Ollama:    CODEX_BASE_URL=http://localhost:11434/v1
# LM Studio: CODEX_BASE_URL=http://localhost:1234/v1
# llama.cpp: CODEX_BASE_URL=http://localhost:8080/v1
#
# CODEX_BASE_URL=http://localhost:11434/v1
# CODEX_MODEL=codellama          # or: deepseek-coder, qwen2.5-coder, starcoder2
# CODEX_API_KEY=local            # local servers ignore this value

# ── Subscription plan ────────────────────────────────────────────────────────
# free       → claude-haiku  + gpt-4o-mini  | 2k tokens | 20 tasks/project
# pro        → claude-sonnet + gpt-4o        | 4k tokens | 200 tasks/project
# enterprise → claude-opus   + gpt-4o        | 8k tokens | unlimited tasks
PLAN=pro

# Optional: override models regardless of plan
# CLAUDE_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-4o

DATABASE_URL=sqlite+aiosqlite:///./collab.db
